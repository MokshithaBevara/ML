print(df.head())
print("Last Five records: ")
print(df.tail())
print("Total number of rows and columns: ")
print(df.shape)
print("Column Names: ")
print(df.columns)
print("Data Types: ")
print(df.dtypes)
print("Dataset Informtaion: ")
df.info()
print("Ättendance Mean: ")
print(df["Attendance"].mean())
print("Average Internal Marks: ")
print(df["InternalMarks"].mean())
print("Average External Marks: ")
print(df["ExternalMarks"].mean())
print("Maximum Internal Marks:",df["InternalMarks"].max())
print("Minimum Internal Marks:",df["InternalMarks"].min())
print("Maximum External Marks:",df["ExternalMarks"].max())
print("Minimum External Marks:",df["ExternalMarks"].min())
print("Standard Deaviation of Internal marks:",df["InternalMarks"].std())
